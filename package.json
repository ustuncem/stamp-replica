{
	"name": "stamp-replica",
	"main": "expo-router/entry",
	"version": "1.0.0",
	"scripts": {
		"start": "expo start",
		"reset-project": "node ./scripts/reset-project.js",
		"prebuild": "expo prebuild",
		"android": "expo start --android",
		"ios": "expo start --ios",
		"commit": "cz",
		"commitlint": "commitlint --edit",
		"sync-deps-if-needed": "node scripts/install-if-manifests-changed.mjs",
		"lint": "biome check .",
		"lint-staged": "lint-staged",
		"check-types": "tsc --noEmit",
		"prepare": "husky"
	},
	"dependencies": {
		"@react-navigation/elements": "^2.9.10",
		"@react-navigation/native": "^7.1.33",
		"@shopify/react-native-skia": "^2.6.2",
		"expo": "~55.0.11",
		"expo-constants": "~55.0.11",
		"expo-device": "~55.0.12",
		"expo-font": "~55.0.6",
		"expo-glass-effect": "~55.0.10",
		"expo-image": "~55.0.8",
		"expo-linking": "~55.0.11",
		"expo-router": "~55.0.10",
		"expo-splash-screen": "~55.0.15",
		"expo-status-bar": "~55.0.5",
		"expo-symbols": "~55.0.7",
		"expo-system-ui": "~55.0.13",
		"expo-web-browser": "~55.0.12",
		"react": "19.2.0",
		"react-dom": "19.2.0",
		"react-native": "0.83.4",
		"react-native-gesture-handler": "~2.30.0",
		"react-native-mmkv": "^4.3.1",
		"react-native-nitro-modules": "^0.35.3",
		"react-native-reanimated": "4.2.1",
		"react-native-safe-area-context": "~5.6.2",
		"react-native-screens": "~4.23.0",
		"react-native-unistyles": "^3.2.2",
		"react-native-vision-camera": "^4.7.3",
		"react-native-worklets": "0.7.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@types/react": "~19.2.2",
		"@types/react-native": "^0.73.0",
		"commitizen": "^4.3.1",
		"cz-conventional-changelog": "^3.3.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"typescript": "~5.9.2"
	},
	"config": {
		"commitizen": {
			"path": "cz-conventional-changelog"
		}
	},
	"lint-staged": {
		"**/src/**/*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"yarn exec biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
		],
		"**/src/**": [
			"yarn exec biome check --no-errors-on-unmatched --files-ignore-unknown=true"
		],
		"*.{js,ts,cjs,mjs,jsx,tsx}": [
			"yarn exec biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
	"trustedDependencies": [
		"@shopify/react-native-skia"
	],
	"private": true
}
